{
  "Logging": {
    "LogLevel": { "Default": "Information", "Microsoft.AspNetCore": "Warning" }
  },
  "AllowedHosts": "*",

  "// 1": "----- PASTE YOUR SQL SERVER CONNECTION STRING BELOW -----",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=DatamintDb;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },

  "// 2": "----- JWT: generate a long random string for Secret (never commit the real value; use user-secrets/env var in production) -----",
  "Jwt": {
    "Secret": "REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS",
    "Issuer": "Datamint.API",
    "Audience": "Datamint.Client",
    "AccessTokenMinutes": "30",
    "RefreshTokenDays": "7"
  },

  "// 3": "----- GOOGLE OAUTH: OAuth 2.0 Web Client ID from Google Cloud Console. Frontend must use the SAME client id. -----",
  "GoogleAuth": {
    "ClientId": "YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com"
  },

  "// 4": "----- EMAIL (MailKit/SMTP). For Gmail use an App Password, not your normal password. -----",
  "Email": {
    "Host": "smtp.gmail.com",
    "Port": "587",
    "Username": "YOUR_EMAIL@gmail.com",
    "Password": "YOUR_APP_PASSWORD",
    "FromAddress": "YOUR_EMAIL@gmail.com",
    "FromName": "Datamint"
  },

  "// 5": "----- FILE STORAGE: root folder for user-uploaded content (currently just profile avatars) -----",
  "FileStorage": {
    "UploadsRootPath": "./uploads"
  },

  "Cors": {
    "AllowedOrigins": [ "https://localhost:4200" ]
  },

  "// 6": "----- APP: Name is the single source of truth for product branding in emails - change it here if the project is ever renamed, nothing else needs editing. LogoUrl is null until a real logo exists - every email falls back to a plain letter mark until then; set it to a publicly-reachable image URL to switch every email over automatically. FrontendBaseUrl is a fallback only used when a request has no Origin/Referer (e.g. a background job) - normal requests build the link from the browser's own Origin/Referer header, so this never goes stale behind a tunnel or a real domain -----",
  "App": {
    "Name": "Datamint",
    "FrontendBaseUrl": "https://localhost:4200",
    "LogoUrl": null
  }
}
