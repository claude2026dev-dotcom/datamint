<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Datamint.Infrastructure</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Datamint.Domain\Datamint.Domain.csproj" />
    <ProjectReference Include="..\Datamint.Application\Datamint.Application.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- EF Core / SQL Server -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" Version="8.0.10" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="8.0.10">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <!-- Email -->
    <PackageReference Include="MailKit" Version="4.17.0" />
    <!-- JWT -->
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="8.0.10" />
    <!-- Google token validation -->
    <PackageReference Include="Google.Apis.Auth" Version="1.68.0" />
    <!-- Password hashing (used by DbSeeder for the default admin account) -->
    <PackageReference Include="BCrypt.Net-Next" Version="4.0.3" />
    <!-- Avatar uploads: decodes + re-encodes every uploaded image server-side (never
         trust/store raw uploaded bytes as-is) and resizes it, used by AvatarImageService -->
    <PackageReference Include="SixLabors.ImageSharp" Version="3.1.12" />
  </ItemGroup>
</Project>
